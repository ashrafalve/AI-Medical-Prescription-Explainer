# ============================================================
# AiMedico Backend - Environment Variables
# Copy this file to .env and fill in values
# ============================================================

# --- App Settings ---
APP_NAME=AiMedico
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True
API_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./aimedico.db
# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aimedico

# --- JWT Auth ---
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3

# --- OCR ---
OCR_ENGINE=tesseract
# tesseract | easyocr
TESSERACT_CMD=/usr/bin/tesseract
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe

# --- File Storage ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,webp,tiff

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/aimedico.log
